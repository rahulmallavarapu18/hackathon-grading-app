# Upstash Redis - Required for data persistence
# These are auto-set when you add the Redis integration in Vercel Storage.
# For local dev: copy these values from the Vercel Storage dashboard.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob - Required for image uploads
# Auto-set when you add a Blob store in Vercel Storage.
BLOB_READ_WRITE_TOKEN=

# Admin panel password - REQUIRED, set this in Vercel Environment Variables
ADMIN_PASSWORD=
